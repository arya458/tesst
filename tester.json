{
  "log": {
    "level": "warning"
  },
  "dns": {
    "independent_cache": true,
    "disable_cache": false,
    "strategy": "ipv4_only",
    "rules": [
      {
        "domain": ["telegram.org", "t.me", "td.telegram.org", "core.telegram.org"],
        "server": "dns-direct"
      },
      {
        "rule_set": ["geosite-telegram"],
        "server": "fakeip"
      }
    ],
    "final": "dns-direct",
    "servers": [
      {
        "type": "local",
        "tag": "dns-direct"
      },
      {
        "type": "fakeip",
        "tag": "fakeip",
        "inet4_range": "10.20.152.0/22"
      }
    ]
  },
  "inbounds": [
    {
      "auto_route": true,
      "endpoint_independent_nat": true,
      "address": ["172.19.0.1/28"],
      "mtu": 9000,
      "stack": "mixed",
      "tag": "tun-in",
      "type": "tun"
    },
    {
      "listen": "127.0.0.1",
      "listen_port": 2080,
      "tag": "mixed-in",
      "type": "mixed"
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "dns-direct",
      "strategy": "ipv4_only"
    },
    "rule_set": [
      {
        "type": "inline",
        "tag": "geosite-telegram",
        "rules": [
          {
            "domain_keyword": ["telegram", "t.me", "td.telegram", "core.telegram"],
            "domain": [
              "telegram.org",
              "t.me",
              "td.telegram.org",
              "core.telegram.org",
              "updates.telegram.org",
              "venus.telegram.org",
              "pluto.telegram.org",
              "web.telegram.org",
              "telegram.dog",
              "telegram.space",
              "graph.org",
              "telegra.ph"
            ],
            "domain_suffix": [
              ".telegram.org",
              ".t.me",
              ".td.telegram.org",
              ".core.telegram.org",
              ".updates.telegram.org",
              ".web.telegram.org",
              ".telegra.ph"
            ]
          }
        ]
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": ["dns"]
      },
      {
        "action": "resolve",
        "strategy": "ipv4_only"
      },
      {
        "action": "route",
        "outbound": "direct",
        "override_address": "www.soft98.ir",
        "rule_set": ["geosite-telegram"]
      },
      {
        "action": "route",
        "outbound": "direct"
      }
    ]
  }
}
